# AI Data Analyst Agent — Environment Variables
# Copy this file to .env and adjust values for your environment.

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175,http://127.0.0.1:3000
# Local dev regex allows Vite fallback ports such as 5174 when 5173 is already busy.
ALLOWED_ORIGIN_REGEX=^http://(localhost|127\.0\.0\.1):\d+$

# ── Upload ────────────────────────────────────────────────────────────────────
# Maximum file size in bytes (default: 100MB)
MAX_UPLOAD_BYTES=104857600

# ── Ollama / LLM ──────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_ROUTER_MODEL=qwen2.5:3b
OLLAMA_ROUTER_TIMEOUT=4
OLLAMA_EXPLAIN_TIMEOUT=8

# ── Code Interpreter ──────────────────────────────────────────────────────────
CODE_INTERPRETER_TIMEOUT=10
CODE_INTERPRETER_MAX_ROWS=100

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false
